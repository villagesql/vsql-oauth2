# End-to-end test of the vsql_oauth2 auth extension over the vsql::preview::auth
# capability: an account binds to IDENTIFIED WITH vsql_oauth2, and a login
# presents a JWT which the extension validates (RS256, static public key) and
# maps to an account.
#
# Fixtures below are a fixed RS256 keypair and pre-signed tokens (sub =
# oauth_mapped_user, iss = https://idp.example). The "valid" token has a
# far-future exp; the "expired" token's exp is in the past. Using precomputed
# tokens keeps the test deterministic with no runtime crypto.
#
# The extension pairs with mysql_clear_password so the token arrives in the
# password slot (client uses --enable_cleartext_plugin).

--source include/not_windows.inc

# Fixed test public key (matches the private key that signed the tokens below).
--let $pubkey= -----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAzN6+QxBZ9p6bUI9Lod/5\nIYtXA3gQ4E+LmtX9jTHSk0EGuaiLYmxNCTifTpqfYJkwjctE8keMDhouCP2CraK0\nkmULDkuF8dbVaK6MXHFjew0yu3K8MCtWbDWTgazszYKvEH3+wDZ1dU7W595KpQSb\nPKiV46LGXIXkAHUtYTJzNmr3ObEbgQFARbAqQa9RLaJwUgSOYOW0qf8TWrRol84B\nZvFle32tJ/xUv9V4ae1ccK4Pbzn0FRymbW1T7JLt7hp/xX2qzQ/KI/1JHoCQkFoz\nfvEt0TGQN1qOo2lrqQjDamQW+W67B9hS5h8Ul/A1TH2p4Xz0wJYrenH8AHaXqyqD\n7wIDAQAB\n-----END PUBLIC KEY-----\n

# Pre-signed tokens (RS256). sub=oauth_mapped_user, iss=https://idp.example.
--let $valid_token= eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJvYXV0aF9tYXBwZWRfdXNlciIsImlzcyI6Imh0dHBzOi8vaWRwLmV4YW1wbGUiLCJleHAiOjk5OTk5OTk5OTl9.jzmGoHnGE7rqoKcHJIlKOiMlBJ-GgPQf8ayCqymCC7BCpujCa8AfklKg48TZQnvejpUrW4yUEtQu0hDTTTMH-ZJC5uWOLyUJ4gXXDBjO2k3skOPmDkDP2nFAbUuxLdDaI_qxwMkj4ze-kYaL1FHn_Q1nTVtUdJg-B37ZvINycvkIHlCREMaloOfCT1hY77dUCiYPobExfLCtY9MC6hMwex2uXaHNvMD0ShW16xW6DVGU3dl84avfA8ODJs2qfD6Bry3QAcvfRsqkyc6TohsljTFVH-TTOgFk2D-0KETK0VGxwDWbnHA-EvbhdAoNucu3RZ-fH0sGJ9KLZRWgPP_-sg
--let $expired_token= eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJvYXV0aF9tYXBwZWRfdXNlciIsImlzcyI6Imh0dHBzOi8vaWRwLmV4YW1wbGUiLCJleHAiOjEwMDAwMDAwMDB9.UgphMR-DZPymzu6n-FQ5s8RVYHYBotFhQGoRnfq5j3bqXRFW_W0nMLVp0X6529D6Nf8wU5BzO8M58dKilqC9kEeNbNnn5BlnvCwAukBWl9FCnQfOBrn4kZnoFxWbXShJg9PEaIEtlhWuWuyJUUiNutoD9mtgTFSVIjw24xsUE9NEfOaQ0vQpXI301boDkNfuhdNhcTLq0rOAwrgXNLlynf_KRt7lI6XOEUuMQXVQ-cKbcEAmaBIrFAKW24r6viwlF1l-8lGv2-XnUv1fjynUNwjcGNqCVrvkotdTyFT_ggWOYkz7xVav46TC0WHe9EHM3xDiUULIaLD3iPxb8IRzAQ

--echo #
--echo # Install the OAuth extension and configure the verification key + issuer.
--echo #
INSTALL EXTENSION vsql_oauth2;

--disable_query_log
eval SET GLOBAL vsql_oauth2.public_key = '$pubkey';
SET GLOBAL vsql_oauth2.issuer = 'https://idp.example';
--enable_query_log

--echo #
--echo # The token maps (sub claim) to oauth_mapped_user; that account must exist
--echo # and the connecting account must be allowed to proxy onto it.
--echo #
CREATE USER oauth_user IDENTIFIED WITH vsql_oauth2;
CREATE USER oauth_mapped_user;
GRANT SELECT ON *.* TO oauth_mapped_user;
GRANT PROXY ON oauth_mapped_user TO oauth_user;

--echo #
--echo # Valid token -> accepted; session runs AS the mapped account and the
--echo # original identity (the sub claim) is exposed via @@external_user.
--echo #
--exec $MYSQL --enable_cleartext_plugin --user=oauth_user --password=$valid_token -e "SELECT CURRENT_USER(), @@external_user"

--echo #
--echo # Expired token -> fail closed.
--echo #
--error 1
--exec $MYSQL --enable_cleartext_plugin --user=oauth_user --password=$expired_token -e "SELECT 1" 2>&1

--echo #
--echo # Garbage token -> fail closed.
--echo #
--error 1
--exec $MYSQL --enable_cleartext_plugin --user=oauth_user --password=not-a-jwt -e "SELECT 1" 2>&1

--echo #
--echo # Empty token -> fail closed.
--echo #
--error 1
--exec $MYSQL --enable_cleartext_plugin --user=oauth_user --password= -e "SELECT 1" 2>&1

--echo #
--echo # With no verification key configured, even a valid token is rejected
--echo # (fail closed: no key source -> no trust).
--echo #
--disable_query_log
SET GLOBAL vsql_oauth2.public_key = '';
--enable_query_log
--error 1
--exec $MYSQL --enable_cleartext_plugin --user=oauth_user --password=$valid_token -e "SELECT 1" 2>&1
--disable_query_log
eval SET GLOBAL vsql_oauth2.public_key = '$pubkey';
--enable_query_log

--echo #
--echo # Without --enable_cleartext_plugin the client refuses to send the token
--echo # in cleartext -> connection fails (client-side gating).
--echo #
--error 1
--exec $MYSQL --user=oauth_user --password=$valid_token -e "SELECT 1" 2>&1

--echo #
--echo # Uninstall removes the method; the account can no longer authenticate.
--echo #
UNINSTALL EXTENSION vsql_oauth2;
--error 1
--exec $MYSQL --enable_cleartext_plugin --user=oauth_user --password=$valid_token -e "SELECT 1" 2>&1

--echo #
--echo # Cleanup.
--echo #
DROP USER oauth_user;
DROP USER oauth_mapped_user;
