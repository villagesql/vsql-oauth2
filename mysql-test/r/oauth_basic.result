#
# Install the OAuth extension and configure the verification key + issuer.
#
INSTALL EXTENSION vsql_oauth2;
#
# The token maps (sub claim) to oauth_mapped_user; that account must exist
# and the connecting account must be allowed to proxy onto it.
#
CREATE USER oauth_user IDENTIFIED WITH vsql_oauth2;
CREATE USER oauth_mapped_user;
GRANT SELECT ON *.* TO oauth_mapped_user;
GRANT PROXY ON oauth_mapped_user TO oauth_user;
#
# Valid token -> accepted; session runs AS the mapped account and the
# original identity (the sub claim) is exposed via @@external_user.
#
CURRENT_USER()	@@external_user
oauth_mapped_user@%	oauth_mapped_user
#
# Expired token -> fail closed.
#
mysql: [Warning] Using a password on the command line interface can be insecure.
ERROR 1045 (28000): Access denied for user 'oauth_user'@'localhost' (using password: NO)
#
# Garbage token -> fail closed.
#
mysql: [Warning] Using a password on the command line interface can be insecure.
ERROR 1045 (28000): Access denied for user 'oauth_user'@'localhost' (using password: NO)
#
# Empty token -> fail closed.
#
mysql: [Warning] Using a password on the command line interface can be insecure.
ERROR 1045 (28000): Access denied for user 'oauth_user'@'localhost' (using password: NO)
#
# With no verification key configured, even a valid token is rejected
# (fail closed: no key source -> no trust).
#
mysql: [Warning] Using a password on the command line interface can be insecure.
ERROR 1045 (28000): Access denied for user 'oauth_user'@'localhost' (using password: NO)
#
# Without --enable_cleartext_plugin the client refuses to send the token
# in cleartext -> connection fails (client-side gating).
#
mysql: [Warning] Using a password on the command line interface can be insecure.
ERROR 2059 (HY000): Authentication plugin 'mysql_clear_password' cannot be loaded: plugin not enabled
#
# Uninstall removes the method; the account can no longer authenticate.
#
UNINSTALL EXTENSION vsql_oauth2;
mysql: [Warning] Using a password on the command line interface can be insecure.
ERROR 1524 (HY000): Plugin 'vsql_oauth2' is not loaded
#
# Cleanup.
#
DROP USER oauth_user;
DROP USER oauth_mapped_user;
